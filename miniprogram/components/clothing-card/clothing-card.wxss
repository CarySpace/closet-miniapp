.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.cover {
  width: 100%;
  height: 240rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: #f2f2f2;
}

.name {
  display: block;
  font-size: 32rpx;
  color: #222222;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 24rpx;
  color: #888888;
}