<view class="page">
  <view class="hero">
    <text class="hero-date">{{dateText}}</text>
    <text class="hero-greeting">{{greeting}}</text>

    <view class="weather-card">
      <view class="weather-info">
        <text class="hero-temp">{{temperature}}</text>
        <text class="hero-weather-text">{{weatherText}}</text>
      </view>

      <text class="weather-icon">☀</text>
    </view>
  </view>
</view>